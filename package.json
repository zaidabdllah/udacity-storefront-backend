{
  "name": "storefront_backend",
  "version": "0.1.0",
  "description": "Storefront backend API built with Node.js, Express, TypeScript, PostgreSQL, JWT authentication, and Jasmine tests.",
  "main": "source/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaidabdllah/udacity-storefront-backend.git"
  },
  "bugs": {
    "url": "https://github.com/zaidabdllah/udacity-storefront-backend/issues"
  },
  "homepage": "https://github.com/zaidabdllah/udacity-storefront-backend#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "ts-node source/index.ts",
    "watch": "tsc-watch --esModuleInterop source/index.ts --outDir ./build --onSuccess \"node ./build/index.js\"",
    "test": "node -e \"const {spawnSync}=require('child_process');const run=(cmd,env={})=>spawnSync(cmd,{stdio:'inherit',shell:true,env:{...process.env,...env}}).status??1;const up=run('npm run migrate:up:test');if(up!==0)process.exit(up);const t=run('cross-env ENV=test jasmine');const down=run('npm run migrate:down:test -- -c 999');process.exit(down!==0?down:t);\"",
    "seed:products": "ts-node source/services/productSeedService.ts",
    "seed:products:test": "cross-env ENV=test ts-node source/services/productSeedService.ts",
    "seed:dump": "ts-node source/services/databaseDumpSeedService.ts",
    "seed:dump:test": "cross-env ENV=test ts-node source/services/databaseDumpSeedService.ts",
    "migrate:create": "db-migrate create --sql-file --config ./source/database/migrations/database.json --migrations-dir ./source/database/migrations",
    "migrate:up": "db-migrate up --config ./source/database/migrations/database.json --migrations-dir ./source/database/migrations --env dev",
    "migrate:down": "db-migrate down --config ./source/database/migrations/database.json --migrations-dir ./source/database/migrations --env dev",
    "migrate:up:test": "db-migrate up --config ./source/database/migrations/database.json --migrations-dir ./source/database/migrations --env test",
    "migrate:down:test": "db-migrate down --config ./source/database/migrations/database.json --migrations-dir ./source/database/migrations --env test"
  },
  "author": "zaid abdallah",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "jasmine": "^6.2.0",
    "jasmine-spec-reporter": "^7.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0"
  }
}
